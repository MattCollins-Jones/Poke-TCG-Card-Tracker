{
  "version": 2,
  "buildCommand": "npm install && cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/sync?phase=prices",
      "schedule": "0 4 * * 1"
    }
  ]
}
